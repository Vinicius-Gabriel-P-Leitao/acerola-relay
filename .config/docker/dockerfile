# Base build image para Rust on Alpine
FROM rust:alpine AS chef

RUN apk add --no-cache musl-dev openssl-dev pkgconfig clang lld
RUN cargo install cargo-chef
WORKDIR /acerola

FROM chef AS planner
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

### Builder image
FROM chef AS rust_builder

# Copia a receita do cargo-chef
COPY --from=planner /acerola/recipe.json recipe.json

# Cache de dependências usando BuildKit Mounts
# Isso preserva o cache do cargo e do target entre builds, se não fizer vai dormir esperando o build
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/acerola/target \
    cargo chef cook --release --recipe-path recipe.json

# Copia o workspace inteiro
COPY . .

# Build do binário usando cache mounts para velocidade incremental
# O uso do lld (via .cargo/config.toml) será ativado pelo clang/lld instalados
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/acerola/target \
    cargo build --release --bin relay --features server && \
    cp target/release/relay /acerola/relay_bin

### Target image (Runtime)
FROM alpine:latest AS acerola-relay

RUN apk update && apk add --no-cache ca-certificates

# Copia apenas o binário final
COPY --from=rust_builder /acerola/relay_bin /relay

RUN chmod +x /relay

WORKDIR /

# Portas padrão
EXPOSE 80 443 7824/udp 9090

ENTRYPOINT ["/relay"]
CMD [""]
